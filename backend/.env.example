# ===== APPLICATION ENVIRONMENT =====
NODE_ENV=production
LOG_LEVEL=info

# ===== MONGODB CONFIGURATION =====
# For production use MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/devleap_db?retryWrites=true&w=majority

# ===== EXPRESS SERVER =====
PORT=5000
FRONTEND_URL=https://yourdomain.com

# ===== JWT AUTHENTICATION =====
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generate_a_secure_random_string_here

# ===== GOOGLE OAUTH =====
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ===== GEMINI AI API =====
# Get from: https://ai.google.dev
GEMINI_API_KEY=your-gemini-api-key

# ===== EMAIL CONFIGURATION (Nodemailer) =====
# Use Gmail App Passwords: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# ===== REDIS CACHE (Optional) =====
# For caching: redis://localhost:6379 or use Redis Cloud
REDIS_URL=redis://localhost:6379

# ===== CODE EXECUTION API =====
# Piston API for code execution (free, no key needed)
PISTON_API_URL=https://emkc.org/api/v2/piston/execute

# ===== RATE LIMITING & SECURITY =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

